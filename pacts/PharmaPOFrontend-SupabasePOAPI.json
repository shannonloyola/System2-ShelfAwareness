{
  "consumer": {
    "name": "PharmaPOFrontend"
  },
  "interactions": [
    {
      "description": "a request to create a new Purchase Order",
      "providerStates": [
        {
          "name": "a valid Purchase Order can be created"
        }
      ],
      "request": {
        "body": {
          "created_at": "2026-01-01T00:00:00Z",
          "expected_delivery_date": null,
          "paid_at": "2026-01-01T00:00:00Z",
          "po_no": "PO-TEST-001",
          "status": "Draft",
          "supplier_name": "Test Supplier"
        },
        "headers": {
          "Content-Type": "application/json",
          "Prefer": "return=representation",
          "apikey": "test-api-key"
        },
        "matchingRules": {
          "header": {
            "apikey": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/rest/v1/purchase_orders"
      },
      "response": {
        "body": {
          "data": [
            {
              "po_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
              "po_no": "PO-TEST-001",
              "status": "Draft",
              "supplier_name": "Test Supplier"
            }
          ],
          "error": null
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data[*].po_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.data[*].po_no": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].supplier_name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "SupabasePOAPI"
  }
}