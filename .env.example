# --- Global Environment Variables ---
NODE_ENV=production
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DB_SSL=true
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
CRON_TIMEZONE=Asia/Manila

# --- Frontend ---
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPPLIER_SERVICE_URL=http://localhost:4001

# --- Service URLs (Internal Docker Communication) ---
# These are used by backend/services to talk to each other inside the Docker network.
# In local development outside Docker, change these to http://localhost:PORT
SUPPLIER_SERVICE_URL=http://supplier-service:4001
PROCUREMENT_SERVICE_URL=http://procurement-service:4002
PRODUCT_CATALOG_SERVICE_URL=http://product-catalog-service:4003
INVENTORY_SERVICE_URL=http://inventory-service:4004
WAREHOUSE_RECEIVING_SERVICE_URL=http://warehouse-receiving-service:4005
DISTRIBUTION_SERVICE_URL=http://distribution-service:4006
DISCREPANCY_QC_SERVICE_URL=http://discrepancy-qc-service:4007
STOCK_ADJUSTMENT_SERVICE_URL=http://stock-adjustment-service:4008
CYCLE_COUNTING_SERVICE_URL=http://cycle-counting-service:4009
RISK_COMPLIANCE_SERVICE_URL=http://risk-compliance-service:4010
NOTIFICATION_SERVICE_URL=http://notification-service:4011
REPORTING_ANALYTICS_SERVICE_URL=http://reporting-analytics-service:4012
DOCUMENT_SERVICE_URL=http://document-service:4013
AUTH_USER_ACCESS_SERVICE_URL=http://auth-user-access-service:4014
BACKEND_API_URL=http://pharma-backend:3001
